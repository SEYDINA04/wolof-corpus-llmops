# ─────────────────────────────────────────────────────────────────────────
# Template de configuration des secrets.
# Copier ce fichier en `.env` (gitignored) et renseigner les vraies valeurs.
#   cp .env.example .env
#
# En CI/CD (GitHub Actions), ces valeurs sont fournies par les *Secrets* du
# dépôt (Settings > Secrets and variables > Actions), PAS par ce fichier.
# ─────────────────────────────────────────────────────────────────────────

# Token HuggingFace avec droit d'écriture sur l'organisation galsenai.
# Créer un token : https://huggingface.co/settings/tokens (role: write)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repo cible du dataset centralisé.
HF_DATASET_REPO=galsenai/wolof_centalized_corpus
